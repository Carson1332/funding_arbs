# =============================================================================
# Environment Variables for funding-arb
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is .gitignored and will NOT be committed.

# CoinAPI key (optional, for premium data source)
COINAPI_KEY= #Your key

# Database URL (optional, defaults to SQLite)
# For PostgreSQL: postgresql://user:password@localhost:5432/funding_arb
DATABASE_URL=

# Docker Compose: PostgreSQL password
DB_PASSWORD=funding_arb_dev
